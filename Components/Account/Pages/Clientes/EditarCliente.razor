        align-items: center;
        gap: 0.75rem;
    }

    .info-card-header i {
        color: #0f172a;
        font-size: 1.25rem;
    }

    .info-card-header h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #1f2937;
        margin: 0;
    }

    .info-card-body {
        padding: 1.5rem;
    }

    .info-item {
        display: flex;
        margin-bottom: 0.75rem;
        font-size: 0.9rem;
    }

    .info-item:last-child {
        margin-bottom: 0;
    }

    .info-label {
        width: 100px;
        color: #6b7280;
    }

    .info-value {
        color: #1f2937;
        font-weight: 500;
    }

    /* Tip Card */
    .tip-card {
        background: rgba(15, 23, 42, 0.05);
