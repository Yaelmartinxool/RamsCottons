@page "/clientes/editar/{Id}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using RamsCottons.Models
@using RamsCottons.Data
@using System.ComponentModel.DataAnnotations

@attribute [Authorize]

@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Editar Cliente | RAMS Cottons</PageTitle>

<div class="editar-cliente-container">
    <br>
    <!-- Header -->
    <div class="dashboard-header">
        <div class="header-content">
            <div class="header-title">
                <div class="title-icon">
                    <i class="bi bi-pencil-fill"></i>
                </div>
                <div>
                    <h1>Editar Cliente</h1>
                    <p class="subtitle">Modifique la información del cliente</p>
                </div>
            </div>
            <button class="btn-back" @onclick="Volver">
                <i class="bi bi-arrow-left"></i>
                <span>Volver</span>
            </button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary"></div>
            <p>Cargando información del cliente...</p>
        </div>
    }
    else if (cliente == null)
    {
        <div class="error-container">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <h3>Cliente no encontrado</h3>
            <p>El cliente que intentas editar no existe o ha sido eliminado.</p>
            <button class="btn-back" @onclick="Volver">Volver</button>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Columna Principal: Formulario -->
            <div class="col-lg-8">
                <div class="form-card">
                    <div class="card-header">
                        <div class="header-left">
                            <i class="bi bi-pencil-square"></i>
                            <h3>Información del Cliente</h3>
                        </div>
                        <span class="required-badge">* Campos obligatorios</span>
                    </div>
                    <div class="card-body">
                        <EditForm Model="modelo" OnValidSubmit="GuardarCliente" FormName="editarCliente">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="validation-summary" />

                            <div class="form-grid">
                                <!-- Nombre Completo -->
                                <div class="form-group full-width">
                                    <label class="form-label">
                                        Nombre Completo <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person input-icon"></i>
                                        <InputText @bind-Value="modelo.NombreCompleto"
                                                class="form-control" />
                                    </div>
                                    <ValidationMessage For="() => modelo.NombreCompleto" class="validation-message" />
                                </div>

                                <!-- Teléfono y Email -->
                                <div class="form-group">
                                    <label class="form-label">
                                        Teléfono <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-telephone input-icon"></i>
                                        <InputText @bind-Value="modelo.Telefono"
                                                class="form-control" />
                                    </div>
                                    <ValidationMessage For="() => modelo.Telefono" class="validation-message" />
                                </div>

                                <div class="form-group">
                                    <label class="form-label">
                                        Correo Electrónico
                                    </label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-envelope input-icon"></i>
                                        <InputText @bind-Value="modelo.Correo"
                                                class="form-control" />
                                    </div>
                                    <ValidationMessage For="() => modelo.Correo" class="validation-message" />
                                </div>

                                <!-- Categoría -->
                                <div class="form-group full-width">
                                    <label class="form-label">Categoría</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-tags input-icon"></i>
                                        <select @bind="modelo.IdCategoriaProducto" class="form-control">
                                            <option value="">Seleccione una categoría</option>
                                            @foreach (var cat in categorias)
                                            {
                                                <option value="@cat.IdCategoria">@cat.NombreCat</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <!-- 🔥 SUPERADMIN: Campos extra para asignar a otro administrador -->
                                @if (esSuperAdmin)
                                {
                                    <div class="form-group full-width">
                                        <label class="form-label">Asignar a Administrador <span class="text-danger">*</span></label>
                                        <div class="input-wrapper">
                                            <i class="bi bi-person-badge input-icon"></i>
                                            <select @bind="selectedAdminId" class="form-control">
                                                <option value="">Seleccione un administrador</option>
                                                @foreach (var admin in administradores)
                                                {
                                                    <option value="@admin.Id">@admin.NombreCompleto (@admin.Email)</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-group full-width">
                                        <label class="form-label">Sucursal <span class="text-danger">*</span></label>
                                        <div class="input-wrapper">
                                            <i class="bi bi-building input-icon"></i>
                                            <select @bind="selectedSucursalId" class="form-control">
                                                @foreach (var suc in sucursales)
                                                {
                                                    <option value="@suc.IdSucursal">@suc.NombreSucursal</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                }

                                <!-- Estado -->
                                <div class="form-group full-width">
                                    <label class="form-label">Estado</label>
                                    <div class="status-toggle">
                                        <label class="toggle-switch">
                                            <InputCheckbox @bind-Value="modelo.Estado" />
                                            <span class="toggle-slider"></span>
                                        </label>
                                        <span class="status-text">@(modelo.Estado ? "Activo" : "Inactivo")</span>
                                    </div>
                                </div>

                                <!-- Mensaje Informativo -->
                                <div class="info-message full-width">
                                    <i class="bi bi-info-circle-fill"></i>
                                    <span>
                                        <strong>Nota:</strong> Al cambiar el teléfono, asegúrate de que no esté registrado en otro cliente.
                                    </span>
                                </div>

                                <!-- Botones de Acción -->
                                <div class="form-actions full-width">
                                    <button type="submit" class="btn-submit" disabled="@guardando">
                                        @if (guardando)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-check-lg me-2"></i>
                                        }
                                        @(guardando ? "Guardando..." : "Guardar Cambios")
                                    </button>
                                    <button type="button" class="btn-cancel" @onclick="Volver">
                                        <i class="bi bi-x-lg me-2"></i>
                                        Cancelar
                                    </button>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>

            <!-- Columna Lateral: Información y Ayuda -->
            <div class="col-lg-4">
                <!-- Tarjeta de Información -->
                <div class="info-card">
                    <div class="info-card-header">
                        <i class="bi bi-person-badge"></i>
                        <h4>Información del Cliente</h4>
                    </div>
                    <div class="info-card-body">
                        <div class="info-item">
                            <span class="info-label">ID:</span>
                            <span class="info-value">CL-@cliente.Id</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Fecha registro:</span>
                            <span class="info-value">@cliente.FechaRegistro.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Registrado por:</span>
                            <span class="info-value">@cliente.IdUsuario</span>
                        </div>
                    </div>
                </div>

                <!-- Tarjeta de Consejo -->
                <div class="tip-card">
                    <i class="bi bi-lightbulb"></i>
                    <div>
                        <h5>Consejo de Edición</h5>
                        <p>Al cambiar el teléfono, verifica que no exista otro cliente con el mismo número para evitar duplicados.</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Toasts -->
    @if (!string.IsNullOrEmpty(mensajeExito))
    {
        <div class="toast-notification toast-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@mensajeExito</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="toast-notification toast-error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@error</span>
        </div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private int ClienteId => int.TryParse(Id, out var id) ? id : 0;

    private Cliente? cliente;
    private List<CategoriaProducto> categorias = new();
    private List<Sucursal> sucursales = new();
    private List<ApplicationUser> administradores = new();
    private bool cargando = true;
    private bool guardando = false;
    private string? error;
    private string? mensajeExito;
    private ClienteModel modelo = new();

    // Variables para SuperAdmin
    private bool esSuperAdmin = false;
    private string selectedAdminId = "";
    private int selectedSucursalId = 1;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        try
        {
            await CargarUsuarioActual();
            
            if (esSuperAdmin)
            {
                await CargarSucursales();
                await CargarAdministradores();
            }

            cliente = await DbContext.Clientes.FirstOrDefaultAsync(c => c.Id == ClienteId);
            
            if (cliente != null)
            {
                modelo = new ClienteModel
                {
                    NombreCompleto = cliente.NombreCompleto,
                    Telefono = cliente.Telefono ?? "",
                    Correo = cliente.Correo,
                    IdCategoriaProducto = cliente.IdCategoriaProducto,
                    Estado = cliente.Estado == 1
                };
                
                // Si es SuperAdmin, cargar los valores actuales
                if (esSuperAdmin)
                {
                    selectedAdminId = cliente.IdUsuario ?? "";
                    selectedSucursalId = cliente.IdSucursal;
                }
            }
            
            categorias = await DbContext.CategoriaProductos.ToListAsync();
        }
        catch (Exception ex)
        {
            error = $"Error cargando datos: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task CargarUsuarioActual()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        esSuperAdmin = user.IsInRole("SuperAdministrador");
    }

    private async Task CargarAdministradores()
    {
        var admins = await UserManager.GetUsersInRoleAsync("Administrador");
        administradores = admins.ToList();
    }

    private async Task CargarSucursales()
    {
        try
        {
            sucursales = await DbContext.Sucursales.ToListAsync();
            if (sucursales.Any())
            {
                selectedSucursalId = sucursales.First().IdSucursal;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando sucursales: {ex.Message}");
        }
    }

    private async Task GuardarCliente()
    {
        if (cliente == null) return;

        guardando = true;
        error = null;
        mensajeExito = null;

        try
        {
            // Verificar si el teléfono ya existe en otro cliente
            var existe = await DbContext.Clientes.AnyAsync(c => c.Telefono == modelo.Telefono && c.Id != ClienteId);
            if (existe)
            {
                error = "Ya existe otro cliente con este número de teléfono.";
                return;
            }

            // Actualizar datos básicos
            cliente.NombreCompleto = modelo.NombreCompleto;
            cliente.Telefono = modelo.Telefono;
            cliente.Correo = modelo.Correo;
            cliente.IdCategoriaProducto = modelo.IdCategoriaProducto > 0 ? modelo.IdCategoriaProducto : null;
            cliente.Estado = modelo.Estado ? 1 : 0;

            // Si es SuperAdmin, actualizar también el administrador y sucursal
            if (esSuperAdmin)
            {
                if (string.IsNullOrEmpty(selectedAdminId))
                {
                    error = "Debes seleccionar un administrador";
                    return;
                }
                cliente.IdUsuario = selectedAdminId;
                cliente.IdSucursal = selectedSucursalId;
            }

            await DbContext.SaveChangesAsync();

            mensajeExito = $"✅ Cliente {cliente.NombreCompleto} actualizado correctamente.";
            
            await Task.Delay(2000);
            NavigationManager.NavigateTo("/clientes");
        }
        catch (Exception ex)
        {
            error = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }

    private void Volver()
    {
        NavigationManager.NavigateTo("/clientes");
    }

    private class ClienteModel
    {
        [Required(ErrorMessage = "El nombre completo es obligatorio")]
        [StringLength(180, MinimumLength = 3, ErrorMessage = "El nombre debe tener entre 3 y 180 caracteres")]
        public string NombreCompleto { get; set; } = "";

        [Required(ErrorMessage = "El teléfono es obligatorio")]
        [RegularExpression(@"^[0-9+\s-]{8,20}$", ErrorMessage = "Formato de teléfono inválido")]
        public string Telefono { get; set; } = "";

        [EmailAddress(ErrorMessage = "Formato de correo inválido")]
        public string? Correo { get; set; }

        public int? IdCategoriaProducto { get; set; }
        
        public bool Estado { get; set; } = true;
    }
}

<style>
    .editar-cliente-container {
        padding-bottom: 2rem;
        min-height: 100vh;
    }

    /* Header */
    .dashboard-header {
        background: white;
