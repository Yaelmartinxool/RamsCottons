    /* Layout de columnas */
    .row {
        display: flex;
        flex-wrap: wrap;
        margin: 0 -0.75rem;
    }

    .col-lg-8 {
        width: 66.666%;
        padding: 0 0.75rem;
    }

    .col-lg-4 {
        width: 33.333%;
        padding: 0 0.75rem;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
