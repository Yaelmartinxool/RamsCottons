        border: 1px solid #e5e7eb;
    }

    .error-container i {
        font-size: 3rem;
        color: #ef4444;
        margin-bottom: 1rem;
    }

    /* Toasts */
    .toast-notification {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        background: white;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
