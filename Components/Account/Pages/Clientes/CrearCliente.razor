@page "/clientes/crear"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using RamsCottons.Models
@using RamsCottons.Data
@using System.ComponentModel.DataAnnotations

@attribute [Authorize]

@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject RoleManager<IdentityRole> RoleManager

<PageTitle>Nuevo Cliente | RAMS Cottons</PageTitle>

<div class="crear-cliente-container">
    <br>
    <!-- Header -->
    <div class="dashboard-header">
        <div class="header-content">
            <div class="header-title">
                <div class="title-icon">
                    <i class="bi bi-person-plus-fill"></i>
                </div>
                <div>
                    <h1>Nuevo Cliente</h1>
                    <p class="subtitle">Registre un nuevo cliente en el sistema</p>
                </div>
            </div>
            <button class="btn-back" @onclick="Volver">
                <i class="bi bi-arrow-left"></i>
                <span>Volver</span>
            </button>
        </div>
    </div>

    <div class="row g-4">
        <!-- Columna Principal: Formulario -->
        <div class="col-lg-8">
            <div class="form-card">
                <div class="card-header">
                    <div class="header-left">
                        <i class="bi bi-pencil-square"></i>
                        <h3>Información del Cliente</h3>
                    </div>
                    <span class="required-badge">* Campos obligatorios</span>
                </div>
                <div class="card-body">
                    <EditForm Model="modelo" OnValidSubmit="GuardarCliente" FormName="crearCliente">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="validation-summary" />

                        <div class="form-grid">
                            <!-- Nombre Completo -->
                            <div class="form-group full-width">
                                <label class="form-label">
                                    Nombre Completo <span class="text-danger">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <i class="bi bi-person input-icon"></i>
                                    <InputText @bind-Value="modelo.NombreCompleto"
                                            class="form-control"
                                            placeholder="Ej: Juan Carlos Pérez" />
                                </div>
                                <ValidationMessage For="() => modelo.NombreCompleto" class="validation-message" />
                            </div>

                            <!-- Teléfono y Email -->
                            <div class="form-group">
                                <label class="form-label">
                                    Teléfono <span class="text-danger">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <i class="bi bi-telephone input-icon"></i>
                                    <InputText @bind-Value="modelo.Telefono"
                                            class="form-control"
                                            placeholder="+521234567890" />
                                </div>
                                <ValidationMessage For="() => modelo.Telefono" class="validation-message" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">
                                    Correo Electrónico
                                </label>
                                <div class="input-wrapper">
                                    <i class="bi bi-envelope input-icon"></i>
                                    <InputText @bind-Value="modelo.Correo"
                                            class="form-control"
                                            placeholder="cliente@correo.com" />
                                </div>
                                <ValidationMessage For="() => modelo.Correo" class="validation-message" />
                            </div>

                            <!-- Categoría -->
                            <div class="form-group full-width">
                                <label class="form-label">Categoría</label>
                                <div class="input-wrapper">
                                    <i class="bi bi-tags input-icon"></i>
                                    <select @bind="modelo.IdCategoriaProducto" class="form-control">
                                        <option value="">Seleccione una categoría</option>
                                        @foreach (var cat in categorias)
                                        {
                                            <option value="@cat.IdCategoria">@cat.NombreCat</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- 🔥 SUPERADMIN: Campos extra para asignar a otro administrador -->
                            @if (esSuperAdmin)
                            {
                                <div class="form-group full-width">
                                    <label class="form-label">Asignar a Administrador <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person-badge input-icon"></i>
                                        <select @bind="selectedAdminId" class="form-control">
                                            <option value="">Seleccione un administrador</option>
                                            @foreach (var admin in administradores)
                                            {
                                                <option value="@admin.Id">@admin.NombreCompleto (@admin.Email)</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group full-width">
                                    <label class="form-label">Sucursal <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-building input-icon"></i>
                                        <select @bind="selectedSucursalId" class="form-control">
                                            @foreach (var suc in sucursales)
                                            {
                                                <option value="@suc.IdSucursal">@suc.NombreSucursal</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            }

                            <!-- Mensaje Informativo -->
                            <div class="info-message full-width">
                                <i class="bi bi-info-circle-fill"></i>
                                <span>
                                    <strong>Nota:</strong> El cliente quedará registrado con estado activo. Puedes generar su código QR después.
                                </span>
                            </div>

                            <!-- Botones de Acción -->
                            <div class="form-actions full-width">
                                <button type="submit" class="btn-submit" disabled="@guardando">
                                    @if (guardando)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-lg me-2"></i>
                                    }
                                    @(guardando ? "Guardando..." : "Guardar Cliente")
                                </button>
                                <button type="button" class="btn-cancel" @onclick="Volver">
                                    <i class="bi bi-x-lg me-2"></i>
                                    Cancelar
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <!-- Columna Lateral: Información y Ayuda -->
        <div class="col-lg-4">
            <!-- Tarjeta de Proceso -->
            <div class="info-card">
                <div class="info-card-header">
                    <i class="bi bi-diagram-3"></i>
                    <h4>Proceso de Registro</h4>
                </div>
                <div class="info-card-body">
                    <div class="process-step">
                        <div class="step-number">1</div>
                        <div class="step-text">Completa el formulario con los datos del cliente</div>
                    </div>
                    <div class="process-step">
                        <div class="step-number">2</div>
                        <div class="step-text">El sistema valida la información</div>
                    </div>
                    <div class="process-step">
                        <div class="step-number">3</div>
                        <div class="step-text">El cliente queda registrado en la base de datos</div>
                    </div>
                    <div class="process-step">
                        <div class="step-number">4</div>
                        <div class="step-text">Genera el código QR para el cliente</div>
                    </div>
                </div>
            </div>

            <!-- Tarjeta de Consejo -->
            <div class="tip-card">
                <i class="bi bi-lightbulb"></i>
                <div>
                    <h5>Consejo de Registro</h5>
                    <p>Utiliza un teléfono válido y un correo electrónico real para que el cliente pueda recibir sus promociones y código QR.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Toasts para notificaciones -->
    @if (!string.IsNullOrEmpty(mensajeExito))
    {
        <div class="toast-notification toast-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@mensajeExito</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="toast-notification toast-error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@error</span>
        </div>
    }
</div>

@code {
    private List<CategoriaProducto> categorias = new();
    private List<Sucursal> sucursales = new();
    private List<ApplicationUser> administradores = new();
    private bool guardando = false;
    private string? error;
    private string? mensajeExito;
    private ClienteModel modelo = new();

    // Variables para SuperAdmin
    private bool esSuperAdmin = false;
    private string selectedAdminId = "";
    private int selectedSucursalId = 1;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        await CargarCategorias();
        await CargarSucursales();
        await CargarUsuarioActual();
        
        if (esSuperAdmin)
        {
            await CargarAdministradores();
        }
    }

    private async Task CargarUsuarioActual()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        esSuperAdmin = user.IsInRole("SuperAdministrador");
    }

    private async Task CargarAdministradores()
    {
        // Obtener todos los usuarios con rol Administrador
        var admins = await UserManager.GetUsersInRoleAsync("Administrador");
        administradores = admins.ToList();
    }

    private async Task CargarSucursales()
    {
        try
        {
            sucursales = await DbContext.Sucursales.ToListAsync();
            if (sucursales.Any())
            {
                selectedSucursalId = sucursales.First().IdSucursal;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando sucursales: {ex.Message}");
        }
    }

    private async Task CargarCategorias()
    {
        try
        {
            categorias = await DbContext.CategoriaProductos.ToListAsync();
        }
        catch (Exception ex)
        {
            error = $"Error cargando categorías: {ex.Message}";
        }
    }

    private async Task GuardarCliente()
    {
        guardando = true;
        error = null;
        mensajeExito = null;

        try
        {
            string idUsuario;
            int idSucursal;

            if (esSuperAdmin)
            {
                // Validar que seleccionó un administrador
                if (string.IsNullOrEmpty(selectedAdminId))
                {
                    error = "Debes seleccionar un administrador";
                    return;
                }
                idUsuario = selectedAdminId;
                idSucursal = selectedSucursalId;
            }
            else
            {
                // Obtener usuario actual
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                var usuario = await UserManager.GetUserAsync(user);
                
                if (usuario == null)
                {
                    error = "No se pudo identificar al usuario actual.";
                    return;
                }
                idUsuario = usuario.Id;
                
                // Obtener la sucursal del usuario (por ahora temporal)
                // TODO: Obtener id_sucursal del usuario
                idSucursal = 1;
            }

            // Verificar si el teléfono ya existe
            var existe = await DbContext.Clientes.AnyAsync(c => c.Telefono == modelo.Telefono);
            if (existe)
            {
                error = "Ya existe un cliente con este número de teléfono.";
                return;
            }

            var cliente = new Cliente
            {
                NombreCompleto = modelo.NombreCompleto,
                Telefono = modelo.Telefono,
                Correo = modelo.Correo,
                IdUsuario = idUsuario,
                IdSucursal = idSucursal,
                IdCategoriaProducto = modelo.IdCategoriaProducto > 0 ? modelo.IdCategoriaProducto : null,
                FechaRegistro = DateTime.Now,
                Estado = 1
            };

            DbContext.Clientes.Add(cliente);
            await DbContext.SaveChangesAsync();

            mensajeExito = $"✅ Cliente {modelo.NombreCompleto} registrado correctamente.";
            
            await Task.Delay(2000);
            NavigationManager.NavigateTo("/clientes");
        }
        catch (Exception ex)
        {
            error = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }

    private void Volver()
    {
        NavigationManager.NavigateTo("/clientes");
    }

    private class ClienteModel
    {
        [Required(ErrorMessage = "El nombre completo es obligatorio")]
        [StringLength(180, MinimumLength = 3, ErrorMessage = "El nombre debe tener entre 3 y 180 caracteres")]
        public string NombreCompleto { get; set; } = "";

        [Required(ErrorMessage = "El teléfono es obligatorio")]
        [RegularExpression(@"^[0-9+\s-]{8,20}$", ErrorMessage = "Formato de teléfono inválido")]
        public string Telefono { get; set; } = "";

        [EmailAddress(ErrorMessage = "Formato de correo inválido")]
        public string? Correo { get; set; }

        public int? IdCategoriaProducto { get; set; }
    }
}

