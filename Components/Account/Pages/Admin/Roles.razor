@page "/admin/roles"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using RamsCottons.Data
@inject AuthenticationStateProvider AuthenticationStateProvider

@attribute [Authorize(Roles = "SuperAdministrador")]

@inject RoleManager<IdentityRole> RoleManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Gestión de Roles | RAMS Cottons</PageTitle>

<!-- Header -->
<br>
<div class="dashboard-header">
    <div class="header-content">
        <div class="header-title">
            <div class="title-icon">
                <i class="bi bi-shield-lock"></i>
            </div>
            <div>
                <h1>Gestión de Roles</h1>
                <p class="subtitle">Administre los roles y permisos del sistema</p>
            </div>
        </div>
        <button class="btn-create" @onclick="CrearRol">
            <i class="bi bi-plus-lg"></i>
            <span>Nuevo Rol</span>
        </button>
    </div>
</div>

<!-- Loading -->
@if (cargando)
{
    <div class="loading-container">
        <div class="spinner-border text-primary"></div>
        <p class="mt-3 text-muted">Cargando roles...</p>
    </div>
}
else
{
    <!-- Main Table -->
    <div class="table-container">
        <div class="table-responsive">
            <table class="crud-table">
                <thead>
                    <tr>
                        <th class="col-role">Rol</th>
                        <th class="col-usuarios">Usuarios</th>
                        <th class="col-permisos">Permisos</th>
                        <th class="col-acciones">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!rolesConDatos.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="no-data">
                                    <i class="bi bi-shield-lock display-4 text-muted"></i>
                                    <p class="mb-0">No hay roles registrados</p>
                                    <button class="btn btn-sm btn-primary mt-3" @onclick="CrearRol">
                                        <i class="bi bi-plus-lg"></i> Crear primer rol
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in rolesConDatos)
                        {
                            <tr class="role-row">
                                <!-- ROL -->
                                <td class="col-role">
                                    <div class="role-info">
                                        <div class="role-icon" style="background: @GetRoleColor(item.Rol.Name);">
                                            @if (item.Rol.Name == "SuperAdministrador")
                                            {
                                                <i class="bi bi-shield-fill-check"></i>
                                            }
                                            else if (item.Rol.Name == "Administrador")
                                            {
                                                <i class="bi bi-person-fill-gear"></i>
                                            }
                                            else if (item.Rol.Name == "Gerente")
                                            {
                                                <i class="bi bi-graph-up"></i>
                                            }
                                            else if (item.Rol.Name == "Vendedor")
                                            {
                                                <i class="bi bi-shop"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-person-badge"></i>
                                            }
                                        </div>
                                        <div class="role-details">
                                            <span class="role-name">@item.Rol.Name</span>
                                            <span class="role-desc">@GetRoleDescription(item.Rol.Name)</span>
                                        </div>
                                    </div>
                                </td>

                                <!-- USUARIOS -->
                                <td class="col-usuarios">
                                    <span class="user-count">@item.UserCount</span>
                                </td>

                                <!-- PERMISOS -->
                                <td class="col-permisos">
                                    <div class="permissions-preview">
                                        <span class="permission-badge">@item.PermissionCount permisos</span>
                                        @if (item.Permisos.Any())
                                        {
                                            <span class="permission-preview-text" title="@string.Join(", ", item.Permisos.Select(p => p.Nombre))">
                                                @string.Join(", ", item.Permisos.Take(3).Select(p => p.Nombre))@(item.Permisos.Count > 3 ? "..." : "")
                                            </span>
                                        }
                                    </div>
                                </td>

                                <!-- ACCIONES -->
                                <td class="col-acciones">
                                    <div class="action-buttons">
                                        <!-- Ver permisos (solo lectura) -->
                                        <button class="btn-action btn-view" @onclick="() => VerPermisos(item.Rol.Name!)" title="Ver permisos">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn-action btn-edit" @onclick="() => EditarRol(item.Rol.Name!)" title="Editar rol">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <!-- Asignar permisos (edición) -->
                                        <button class="btn-action btn-permissions" @onclick="() => AsignarPermisos(item.Rol.Name!)" title="Asignar permisos">
                                            <i class="bi bi-shield-check"></i>
                                        </button>
                                        @if (item.Rol.Name != "SuperAdministrador" && item.Rol.Name != "Administrador" && 
                                             item.Rol.Name != "Gerente" && item.Rol.Name != "Vendedor")
                                        {
                                            <button class="btn-action btn-delete" @onclick="() => ConfirmarEliminar(item.Rol)" title="Eliminar rol">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal Eliminar -->
@if (mostrarModalEliminar && rolEliminar != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); backdrop-filter: blur(5px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button class="btn-close-custom" @onclick="CerrarModal">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
                <div class="modal-body text-center p-4">
                    <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-4"
                         style="width: 80px; height: 80px;">
                        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 2.5rem;"></i>
                    </div>
                    
                    <h5 class="fw-bold mb-3">¿Eliminar rol?</h5>
                    <p class="text-muted mb-4">
                        Estás a punto de eliminar el rol 
                        <span class="fw-bold text-dark">@rolEliminar.Name</span>
                        <br>Esta acción no se puede deshacer.
                    </p>
                </div>
                <div class="modal-footer justify-content-center border-0 pb-4">
                    <button class="btn btn-light px-5 py-2 rounded-3" @onclick="CerrarModal">
                        Cancelar
                    </button>
                    <button class="btn btn-danger px-5 py-2 rounded-3" @onclick="EliminarRol">
                        <i class="bi bi-trash3 me-2"></i>
                        Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<RoleWithData> rolesConDatos = new();
    private bool cargando = true;
    private bool mostrarModalEliminar = false;
    private IdentityRole? rolEliminar;

    private class RoleWithData
    {
        public IdentityRole Rol { get; set; } = new();
        public int UserCount { get; set; }
        public int PermissionCount { get; set; }
        public List<Permiso> Permisos { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarRoles();
    }

    private async Task CargarRoles()
    {
        cargando = true;

        try
        {
            rolesConDatos.Clear();

            var roles = await RoleManager.Roles.ToListAsync();

            var users = await DbContext.Users.ToListAsync();
            var rolesPermisos = await DbContext.RolesPermisos.ToListAsync();
            var permisos = await DbContext.Permisos.ToListAsync();

            foreach (var rol in roles)
            {
                var userCount = await UserManager.GetUsersInRoleAsync(rol.Name!);

                var permisosDelRol = rolesPermisos
                    .Where(rp => rp.RoleId == rol.Id)
                    .Join(permisos,
                        rp => rp.PermisoId,
                        p => p.Id,
                        (rp, p) => p)
                    .ToList();

                rolesConDatos.Add(new RoleWithData
                {
                    Rol = rol,
                    UserCount = userCount.Count,
                    PermissionCount = permisosDelRol.Count,
                    Permisos = permisosDelRol
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando roles: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private string GetRoleColor(string? roleName)
    {
        if (string.IsNullOrWhiteSpace(roleName))
            return "linear-gradient(135deg, #64748b, #475569)";

        return roleName switch
        {
            "SuperAdministrador" => "linear-gradient(135deg, #7c3aed, #5b21b6)",
            "Administrador" => "linear-gradient(135deg, #1e293b, #0f172a)",
            "Gerente" => "linear-gradient(135deg, #0891b2, #0e7490)",
            "Vendedor" => "linear-gradient(135deg, #059669, #047857)",
            _ => "linear-gradient(135deg, #64748b, #475569)"
        };
    }

    private string GetRoleDescription(string? roleName)
    {
        if (string.IsNullOrWhiteSpace(roleName))
            return "Rol personalizado";

        return roleName switch
        {
            "SuperAdministrador" => "Control total del sistema, todos los permisos",
            "Administrador" => "Administración por sucursal, puede crear usuarios",
            "Gerente" => "Supervisión, reportes, ver todo",
            "Vendedor" => "Registrar clientes y ver promociones",
            _ => "Rol personalizado"
        };
    }

    private void CrearRol()
    {
        NavigationManager.NavigateTo("/admin/roles/crear");
    }

    private void EditarRol(string roleName)
    {
        if (string.IsNullOrWhiteSpace(roleName)) return;
        NavigationManager.NavigateTo($"/admin/roles/edit/{Uri.EscapeDataString(roleName)}");
    }

    private void VerPermisos(string roleName)
    {
        if (string.IsNullOrWhiteSpace(roleName)) return;
        NavigationManager.NavigateTo($"/admin/roles/permisos/{Uri.EscapeDataString(roleName)}?mode=view");
    }

    private void AsignarPermisos(string roleName)
    {
        if (string.IsNullOrWhiteSpace(roleName)) return;
        NavigationManager.NavigateTo($"/admin/roles/permisos/{Uri.EscapeDataString(roleName)}?mode=edit");
    }

    private void ConfirmarEliminar(IdentityRole rol)
    {
        rolEliminar = rol;
        mostrarModalEliminar = true;
    }

    private void CerrarModal()
    {
        mostrarModalEliminar = false;
        rolEliminar = null;
    }

    private async Task EliminarRol()
    {
        if (rolEliminar == null) return;

        try
        {
            var permisosAsignados = await DbContext.RolesPermisos
                .Where(rp => rp.RoleId == rolEliminar.Id)
                .ToListAsync();

            DbContext.RolesPermisos.RemoveRange(permisosAsignados);
            await DbContext.SaveChangesAsync();

            await RoleManager.DeleteAsync(rolEliminar);

            await CargarRoles();
            CerrarModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al eliminar rol: {ex.Message}");
        }
    }
}

<style>
    /* Variables globales */
    :root {
        --primary: #0f172a;
        --primary-dark: #020617;
        --success: #10b981;
        --warning: #f59e0b;
        --info: #3b82f6;
        --danger: #ef4444;
        --dark: #1f2937;
        --light: #f8fafc;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
