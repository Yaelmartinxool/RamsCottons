        background: white;
        border-color: var(--primary);
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
    }

    .role-card.selected {
        background: rgba(15, 23, 42, 0.05);
        border-color: var(--primary);
        border-width: 2px;
    }

    .role-icon {
        width: 36px;
        height: 36px;
        background: white;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.1rem;
        border: 1px solid var(--gray-200);
    }

    .role-info {
