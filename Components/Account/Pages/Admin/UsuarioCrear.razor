        border: 1px solid var(--danger);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        color: var(--danger);
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        grid-column: 1 / -1;
    }

    .roles-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-top: 0.5rem;
    }

    .role-card {
        background: var(--gray-50);
        border: 1px solid var(--gray-200);
        border-radius: 12px;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
