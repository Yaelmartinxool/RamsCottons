@page "/admin/usuarios/edit/{UserId}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@using RamsCottons.Data

@attribute [Authorize(Roles = "SuperAdministrador,Administrador")]

@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager NavigationManager

<PageTitle>Editar Usuario | RAMS Cottons</PageTitle>
<br>
@if (cargandoInicial)
{
    <div class="loading-container">
        <div class="spinner-border text-primary"></div>
        <p>Cargando información del usuario...</p>
    </div>
}
else if (usuario is null)
{
    <div class="error-container">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <h3>Usuario no encontrado</h3>
        <p>El usuario que intentas editar no existe o ha sido eliminado.</p>
        <button class="btn-back" @onclick="Volver">
            <i class="bi bi-arrow-left"></i>
            <span>Volver a Usuarios</span>
        </button>
    </div>
}
else
{
    <div class="edit-user-container">
        <!-- Header -->
        <div class="dashboard-header">
            <div class="header-content">
                <div class="header-title">
                    <div class="title-icon">
                        <i class="bi bi-pencil-fill"></i>
                    </div>
                    <div>
                        <h1>Editar Usuario</h1>
                        <p class="subtitle">Modifique la información del miembro en el sistema</p>
                    </div>
                </div>
                <button class="btn-back" @onclick="Volver">
                    <i class="bi bi-arrow-left"></i>
                    <span>Volver a Usuarios</span>
                </button>
            </div>
        </div>

        <div class="row g-4">
            <!-- Columna Principal: Formulario -->
            <div class="col-lg-8">
                <div class="form-card">
                    <div class="card-header">
                        <div class="header-left">
                            <i class="bi bi-pencil-square"></i>
                            <h3>Información del Usuario</h3>
                        </div>
                        <span class="required-badge">* Campos obligatorios</span>
                    </div>
                    <div class="card-body">
                        <EditForm Model="modelo" OnValidSubmit="Guardar" FormName="editarUsuario">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="validation-summary" />

                            <div class="form-grid">
                                <!-- Nombre Completo -->
                                <div class="form-group full-width">
                                    <label class="form-label">
                                        Nombre Completo <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person input-icon"></i>
                                        <InputText @bind-Value="modelo.NombreCompleto"
                                                class="form-control"
                                                placeholder="Ej: Juan Carlos Pérez" />
                                    </div>
                                    <ValidationMessage For="() => modelo.NombreCompleto" class="validation-message" />
                                </div>
                                <!-- Nombre de Usuario (Login) -->
<div class="form-group full-width">
    <label class="form-label">
        Nombre de Usuario <span class="text-danger">*</span>
    </label>
    <div class="input-wrapper">
        <i class="bi bi-at input-icon"></i>
        <InputText @bind-Value="modelo.UserName"
                class="form-control"
                placeholder="usuario" />
    </div>
    <ValidationMessage For="() => modelo.UserName" class="validation-message" />
    <span class="field-hint">Nombre único para iniciar sesión</span>
</div>

                                <!-- Email y Teléfono -->
                                <div class="form-group">
                                    <label class="form-label">
                                        Correo Electrónico <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-envelope input-icon"></i>
                                        <InputText @bind-Value="modelo.Email"
                                                class="form-control"
                                                placeholder="usuario@ramscottons.com" />
                                    </div>
                                    <ValidationMessage For="() => modelo.Email" class="validation-message" />
                                </div>

                                <div class="form-group">
                                    <label class="form-label">
                                        Teléfono <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-telephone input-icon"></i>
                                        <InputText @bind-Value="modelo.Telefono"
                                                class="form-control"
                                                placeholder="+521234567890" />
                                    </div>
                                    <ValidationMessage For="() => modelo.Telefono" class="validation-message" />
                                    <span class="field-hint">Formato internacional</span>
                                </div>

                                <!-- Estado del Usuario -->
                                <div class="form-group full-width">
                                    <label class="form-label">Estado de la Cuenta</label>
                                    <div class="status-toggle">
                                        <label class="toggle-switch">
                                            <InputCheckbox @bind-Value="modelo.Activo" />
                                            <span class="toggle-slider"></span>
                                        </label>
                                        <div class="status-info">
                                            <span class="status-badge @(modelo.Activo ? "status-active" : "status-inactive")">
                                                <i class="bi @(modelo.Activo ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                                                @(modelo.Activo ? "Activo" : "Inactivo")
                                            </span>
                                            <span class="status-hint">
                                                @(modelo.Activo ? "El usuario puede acceder al sistema" : "El usuario no podrá iniciar sesión")
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Confirmación de Email -->
                                <div class="form-group full-width">
                                    <label class="form-label">Confirmación de Email</label>
                                    <div class="email-confirmation-status">
                                        <div class="confirmation-info">
                                            <i class="bi @(usuario.EmailConfirmed ? "bi-check-circle-fill text-success" : "bi-exclamation-triangle-fill text-warning")"></i>
                                            <span>
                                                @if (usuario.EmailConfirmed)
                                                {
                                                    <span>Email confirmado <span class="text-muted">· El usuario verificó su correo</span></span>
                                                }
                                                else
                                                {
                                                    <span>Email no confirmado <span class="text-muted">· Pendiente de verificación</span></span>
                                                }
                                            </span>
                                        </div>
                                        @if (!usuario.EmailConfirmed)
                                        {
                                            <button type="button" class="btn-confirm-email" @onclick="ReenviarConfirmacion" disabled="@reenviandoConfirmacion">
                                                @if (reenviandoConfirmacion)
                                                {
                                                    <span class="spinner-border spinner-border-sm"></span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-envelope-check"></i>
                                                }
                                                @(reenviandoConfirmacion ? "Enviando..." : "Reenviar correo de confirmación")
                                            </button>
                                        }
                                    </div>
                                </div>

                                <!-- Roles (Selector Visual) -->
                                <div class="form-group full-width">
                                    <label class="form-label">
                                        Rol de Usuario <span class="text-danger">*</span>
                                    </label>
                                    <ValidationMessage For="() => modelo.Rol" class="validation-message" />
                                    <div class="roles-grid">
                                        @foreach (var rol in roles.Where(r => !string.IsNullOrEmpty(r.Name)))
                                        {
                                            var roleName = rol.Name!;
                                            var isSelected = modelo.Rol == roleName;
                                            <div class="role-card @(isSelected ? "selected" : "")" @onclick="() => SeleccionarRol(roleName)">
                                                <div class="role-icon">
                                                    @if (rol.Name == "SuperAdministrador")
                                                    {
                                                        <i class="bi bi-shield-fill-check"></i>
                                                    }
                                                    else if (rol.Name == "Administrador")
                                                    {
                                                        <i class="bi bi-person-fill-gear"></i>
                                                    }
                                                    else if (rol.Name == "Gerente")
                                                    {
                                                        <i class='bi bi-graph-up'></i>
                                                    }
                                                    else if (rol.Name == "Vendedor")
                                                    {
                                                        <i class='bi bi-shop'></i>
                                                    }
                                                    else
                                                    {
                                                        <i class='bi bi-person-badge'></i>
                                                    }
                                                </div>
                                                <div class="role-info">
                                                    <span class="role-name">@rol.Name</span>
                                                    <span class="role-desc">@GetRoleDescription(rol.Name)</span>
                                                </div>
                                                <div class="role-check">
                                                    @if (isSelected)
                                                    {
                                                        <i class="bi bi-check-circle-fill"></i>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>

                

                                <!-- Botones de Acción -->
                                <div class="form-actions full-width">
                                    <button type="submit" class="btn-submit" disabled="@guardando">
                                        @if (guardando)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-check-lg me-2"></i>
                                        }
                                        @(guardando ? "Guardando..." : "Guardar Cambios")
                                    </button>
                                    <button type="button" class="btn-cancel" @onclick="Volver">
                                        <i class="bi bi-x-lg me-2"></i>
                                        Cancelar
                                    </button>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>

            <!-- Columna Lateral: Información y Ayuda -->
            <div class="col-lg-4">
                <!-- Tarjeta de Información del Usuario -->
                <div class="info-card">
                    <div class="info-card-header">
                        <i class="bi bi-person-badge"></i>
                        <h4>Información del Usuario</h4>
                    </div>
                    <div class="info-card-body">
                        <div class="user-info-item">
                            <span class="info-label">ID:</span>
                            <span class="info-value">@usuario.Id</span>
                        </div>
                        <div class="user-info-item">
                            <span class="info-label">Nombre de usuario:</span>
                            <span class="info-value">@usuario.UserName</span>
                        </div>
                
                    </div>
                </div>

                <!-- Tarjeta de Roles -->
                <div class="info-card">
                    <div class="info-card-header">
                        <i class="bi bi-shield-check"></i>
                        <h4>Roles Disponibles</h4>
                    </div>
                    <div class="info-card-body">
                     <div class="role-info-item">
    <span class="role-tag role-tag-superadmin">
        <i class="bi bi-shield-fill-check me-1"></i>
        SuperAdministrador
    </span>
    <p class="role-description">Control total del sistema, todos los permisos.</p>
</div>
<div class="role-info-item">
    <span class="role-tag role-tag-admin">
        <i class="bi bi-person-fill-gear me-1"></i>
        Administrador
    </span>
    <p class="role-description">Administración por sucursal, puede crear usuarios.</p>
</div>
<div class="role-info-item">
    <span class="role-tag role-tag-gerente">
        <i class="bi bi-graph-up me-1"></i>
        Gerente
    </span>
    <p class="role-description">Supervisión, reportes, acceso a todas las sucursales.</p>
</div>
<div class="role-info-item">
    <span class="role-tag role-tag-vendedor">
        <i class="bi bi-shop me-1"></i>
        Vendedor
    </span>
    <p class="role-description">Registrar clientes y ver promociones.</p>
</div>
                    </div>
                </div>

                <!-- Tarjeta de Consejo -->
                <div class="tip-card">
                    <i class="bi bi-lightbulb"></i>
                    <div>
                        <h5>Consejo de Edición</h5>
                        <p>Al cambiar el email del usuario, asegúrate de que sea correcto. Si desactivas la cuenta, el usuario no podrá acceder hasta que la reactives.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toasts para notificaciones -->
@if (!string.IsNullOrEmpty(mensajeExito))
{
    <div class="toast-notification toast-success">
        <i class="bi bi-check-circle-fill"></i>
        <span>@mensajeExito</span>
    </div>
}

@if (!string.IsNullOrEmpty(error))
{
    <div class="toast-notification toast-error">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@error</span>
    </div>
}

@code {
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    private ApplicationUser? usuario;
    private bool cargandoInicial = true;
    private bool guardando;
    private bool reenviandoConfirmacion;
    private string? error;
    private string? mensajeExito;
    private List<IdentityRole> roles = new();

    private EditModel modelo = new();

    protected override async Task OnInitializedAsync()
    {
        roles = await RoleManager.Roles.ToListAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await CargarUsuario();
    }

    private async Task CargarUsuario()
    {
        cargandoInicial = true;
        error = null;

        try
        {
            usuario = await UserManager.FindByIdAsync(UserId);

            if (usuario is not null)
            {
                var userRoles = await UserManager.GetRolesAsync(usuario);
                
               modelo = new EditModel
{
    NombreCompleto = usuario.NombreCompleto,
    UserName = usuario.UserName,
    Email = usuario.Email,
    Telefono = usuario.Telefono,
    Activo = usuario.Activo,
    Rol = userRoles.FirstOrDefault() ?? ""
};
            }
        }
        catch (Exception ex)
        {
            error = $"Error al cargar el usuario: {ex.Message}";
        }
        finally
        {
            cargandoInicial = false;
        }
    }

    private void SeleccionarRol(string rol)
    {
        modelo.Rol = rol;
    }

private string GetRoleDescription(string? rol)
{
    return rol switch
    {
        "SuperAdministrador" => "Control total del sistema, todos los permisos",
        "Administrador" => "Administración por sucursal, puede crear usuarios",
        "Gerente" => "Supervisión, reportes, ver todo",
        "Vendedor" => "Registrar clientes y ver promociones",
        _ => "Acceso al sistema"
    };
}

   private async Task Guardar()
{
    if (usuario is null)
        return;

    guardando = true;
    error = null;
    mensajeExito = null;

    try
    {
        // Verificar si el email ya está en uso por otro usuario
        if (usuario.Email != modelo.Email)
        {
            var existingUser = await UserManager.FindByEmailAsync(modelo.Email!);
            if (existingUser != null && existingUser.Id != usuario.Id)
            {
                error = "Ya existe otro usuario con este correo electrónico.";
                return;
            }
        }

        // VERIFICAR NOMBRE DE USUARIO (AGREGA ESTO)
        if (usuario.UserName != modelo.UserName)
        {
            var existingUser = await UserManager.FindByNameAsync(modelo.UserName!);
            if (existingUser != null && existingUser.Id != usuario.Id)
            {
                error = "Ya existe otro usuario con este nombre de usuario.";
                return;
            }
        }

        // Actualizar datos básicos
        usuario.NombreCompleto = modelo.NombreCompleto;
        usuario.UserName = modelo.UserName;
        usuario.Email = modelo.Email;
        usuario.Telefono = modelo.Telefono;
        usuario.Activo = modelo.Activo;

        var updateResult = await UserManager.UpdateAsync(usuario);

        if (!updateResult.Succeeded)
        {
            error = string.Join(", ", updateResult.Errors.Select(e => e.Description));
            return;
        }

        // Actualizar rol
        var rolesActuales = await UserManager.GetRolesAsync(usuario);
        if (rolesActuales.Any())
        {
            await UserManager.RemoveFromRolesAsync(usuario, rolesActuales);
        }
        
        if (!string.IsNullOrEmpty(modelo.Rol))
        {
            await UserManager.AddToRoleAsync(usuario, modelo.Rol);
        }

        mensajeExito = $"Usuario {modelo.NombreCompleto} actualizado correctamente.";
        
        // Recargar datos actualizados
        await CargarUsuario();

        // Redirigir después de 2 segundos
        await Task.Delay(2000);
        NavigationManager.NavigateTo("/admin/usuarios");
    }
    catch (Exception ex)
    {
        error = $"Error inesperado: {ex.Message}";
    }
    finally
    {
        guardando = false;
    }
}

   private Task ReenviarConfirmacion()
{
    if (usuario is null || usuario.EmailConfirmed)
        return Task.CompletedTask;

    reenviandoConfirmacion = true;
    error = null;
    mensajeExito = null;

    try
    {
        mensajeExito = $"📧 Correo de confirmación reenviado a {usuario.Email}";
    }
    catch (Exception ex)
    {
        error = $"Error al reenviar correo: {ex.Message}";
    }
    finally
    {
        reenviandoConfirmacion = false;
    }

    return Task.CompletedTask;
}

    private void Volver()
    {
        NavigationManager.NavigateTo("/admin/usuarios");
    }

private class EditModel
{
    [Required(ErrorMessage = "El nombre completo es obligatorio")]
    public string? NombreCompleto { get; set; }

    [Required(ErrorMessage = "El nombre de usuario es obligatorio")]
    public string? UserName { get; set; }

    [Required(ErrorMessage = "El correo es obligatorio")]
    [EmailAddress(ErrorMessage = "Formato de correo inválido")]
    public string? Email { get; set; }

    [Required(ErrorMessage = "El teléfono es obligatorio")]
    public string? Telefono { get; set; }

    public bool Activo { get; set; }

    [Required(ErrorMessage = "Debes seleccionar un rol")]
    public string Rol { get; set; } = "";
}
}

