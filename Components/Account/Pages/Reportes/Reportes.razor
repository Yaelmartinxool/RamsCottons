@page "/reportes"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using RamsCottons.Models
@using RamsCottons.Data
@attribute [Authorize(Roles = "SuperAdministrador,Administrador,Gerente")]

@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Reportes | RAMS Cottons</PageTitle>

<div class="reportes-container">
    <br>
    <!-- Header -->
    <div class="dashboard-header">
        <div class="header-content">
            <div class="header-title">
                <div class="title-icon">
                    <i class="bi bi-graph-up"></i>
                </div>
                <div>
                    <h1>Reportes</h1>
                    <p class="subtitle">Estadísticas del sistema</p>
                </div>
            </div>
            <div class="header-actions">
                <button class="btn-export" @onclick="ExportarExcel">
                    <i class="bi bi-file-earmark-excel-fill"></i> Exportar
                </button>
                <button class="btn-delete-all" @onclick="EliminarTodoConfirmado">
                    <i class="bi bi-trash3-fill"></i> Eliminar todo
                </button>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="tabs-container">
        <div class="tabs">
            <button class="tab-btn @(tabActivo == 1 ? "active" : "")" @onclick="() => CambiarTab(1)">
                <i class="bi bi-people-fill"></i> Clientes
            </button>
            <button class="tab-btn @(tabActivo == 2 ? "active" : "")" @onclick="() => CambiarTab(2)">
                <i class="bi bi-megaphone-fill"></i> Promociones
            </button>
            <button class="tab-btn @(tabActivo == 3 ? "active" : "")" @onclick="() => CambiarTab(3)">
                <i class="bi bi-whatsapp"></i> Envíos
            </button>
            <button class="tab-btn @(tabActivo == 4 ? "active" : "")" @onclick="() => CambiarTab(4)">
                <i class="bi bi-pie-chart-fill"></i> Resumen
            </button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary"></div>
            <p>Cargando...</p>
        </div>
    }
    else
    {
        <!-- Tab Clientes -->
        @if (tabActivo == 1)
        {
            <div class="report-card">
                <div class="report-header">
                    <h3><i class="bi bi-people-fill"></i> Clientes</h3>
                    <div class="filtros">
                        <select class="select-filter" @bind="filtroDias" @bind:event="onchange">
                            <option value="7">Últimos 7 días</option>
                            <option value="15">Últimos 15 días</option>
                            <option value="30">Últimos 30 días</option>
                            <option value="0">Todos</option>
                        </select>
                        <button class="btn-aplicar" @onclick="CargarClientes">Aplicar</button>
                    </div>
                </div>
                <div class="report-body">
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
                            <div class="stat-info">
                                <span class="stat-label">Total</span>
                                <span class="stat-number">@totalClientes</span>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon green"><i class="bi bi-check-circle-fill"></i></div>
                            <div class="stat-info">
                                <span class="stat-label">Activos</span>
                                <span class="stat-number">@clientesActivos</span>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon red"><i class="bi bi-x-circle-fill"></i></div>
                            <div class="stat-info">
                                <span class="stat-label">Inactivos</span>
                                <span class="stat-number">@clientesInactivos</span>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon orange"><i class="bi bi-calendar-plus-fill"></i></div>
                            <div class="stat-info">
                                <span class="stat-label">Nuevos (mes)</span>
                                <span class="stat-number">@clientesNuevosMes</span>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="report-table">
                            <thead>
                                <tr><th>Nombre</th><th>Teléfono</th><th>Correo</th><th>Fecha Registro</th><th>Estado</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var cliente in ultimosClientes)
                                {
                                    <tr>
                                        <td>@cliente.NombreCompleto</td>
                                        <td>@cliente.Telefono</td>
                                        <td>@(cliente.Correo ?? "-")</td>
                                        <td>@cliente.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                        <td><span class="badge @(cliente.Estado == 1 ? "active" : "inactive")">@(cliente.Estado == 1 ? "Activo" : "Inactivo")</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Tab Promociones -->
        @if (tabActivo == 2)
        {
            <div class="report-card">
                <div class="report-header">
                    <h3><i class="bi bi-megaphone-fill"></i> Promociones</h3>
                </div>
                <div class="report-body">
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon purple"><i class="bi bi-megaphone-fill"></i></div>
                            <div class="stat-info"><span class="stat-label">Total</span><span class="stat-number">@totalPromociones</span></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon green"><i class="bi bi-check-circle-fill"></i></div>
                            <div class="stat-info"><span class="stat-label">Activas</span><span class="stat-number">@promocionesActivas</span></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon red"><i class="bi bi-x-circle-fill"></i></div>
                            <div class="stat-info"><span class="stat-label">Inactivas</span><span class="stat-number">@promocionesInactivas</span></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon orange"><i class="bi bi-calendar-exclamation-fill"></i></div>
                            <div class="stat-info"><span class="stat-label">Por vencer</span><span class="stat-number">@promocionesPorVencer</span></div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="report-table">
                            <thead>
                                <tr><th>Título</th><th>Precio</th><th>Descuento</th><th>Inicio</th><th>Fin</th><th>Estado</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var promo in ultimasPromociones)
                                {
                                    <tr>
                                        <td>@promo.Titulo</td>
                                        <td>$@promo.Precio.ToString("N2")</td>
                                        <td>@(promo.DescuentoPorcentaje.HasValue ? $"{promo.DescuentoPorcentaje}% OFF" : "-")</td>
                                        <td>@promo.FechaInicio.ToString("dd/MM/yyyy")</td>
                                        <td>@promo.FechaFin.ToString("dd/MM/yyyy")</td>
                                        <td><span class="badge @(promo.Activo ? "active" : "inactive")">@(promo.Activo ? "Activa" : "Inactiva")</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Tab Envíos -->
        @if (tabActivo == 3)
        {
            <div class="report-card">
                <div class="report-header">
                    <h3><i class="bi bi-whatsapp"></i> Envíos WhatsApp</h3>
                    <div class="filtros">
                        <select class="select-filter" @bind="filtroDiasEnvios" @bind:event="onchange">
                            <option value="7">Últimos 7 días</option>
                            <option value="15">Últimos 15 días</option>
                            <option value="30">Últimos 30 días</option>
                            <option value="0">Todos</option>
                        </select>
                        <button class="btn-aplicar" @onclick="CargarEnvios">Aplicar</button>
                    </div>
                </div>
                <div class="report-body">
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon green"><i class="bi bi-whatsapp"></i></div>
                            <div class="stat-info"><span class="stat-label">Total Envíos</span><span class="stat-number">@totalEnvios</span></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon blue"><i class="bi bi-graph-up"></i></div>
                            <div class="stat-info"><span class="stat-label">Promedio/día</span><span class="stat-number">@promedioDiario</span></div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="report-table">
                            <thead>
                                <tr><th>Cliente</th><th>Teléfono</th><th>Promoción</th><th>Fecha Envío</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var envio in enviosConDatos)
                                {
                                    <tr>
                                        <td>@envio.ClienteNombre</td>
                                        <td>@envio.ClienteTelefono</td>
                                        <td>@envio.PromocionTitulo</td>
                                        <td>@envio.FechaEnvio.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Tab Resumen -->
        @if (tabActivo == 4)
        {
            <div class="report-card">
                <div class="report-header">
                    <h3><i class="bi bi-pie-chart-fill"></i> Resumen General</h3>
                </div>
                <div class="report-body">
                    <div class="resumen-grid">
                        <div class="resumen-item">
                            <div class="resumen-icon blue"><i class="bi bi-people-fill"></i></div>
                            <div class="resumen-info">
                                <span class="resumen-label">Clientes</span>
                                <span class="resumen-number">@totalClientes</span>
                                <span class="resumen-change">+@clientesNuevosMes este mes</span>
                            </div>
                        </div>
                        <div class="resumen-item">
                            <div class="resumen-icon purple"><i class="bi bi-megaphone-fill"></i></div>
                            <div class="resumen-info">
                                <span class="resumen-label">Promociones Activas</span>
                                <span class="resumen-number">@promocionesActivas</span>
                            </div>
                        </div>
                        <div class="resumen-item">
                            <div class="resumen-icon green"><i class="bi bi-whatsapp"></i></div>
                            <div class="resumen-info">
                                <span class="resumen-label">Envíos Realizados</span>
                                <span class="resumen-number">@totalEnvios</span>
                            </div>
                        </div>
                        <div class="resumen-item">
                            <div class="resumen-icon orange"><i class="bi bi-person-badge"></i></div>
                            <div class="resumen-info">
                                <span class="resumen-label">Usuarios</span>
                                <span class="resumen-number">@totalUsuarios</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private int tabActivo = 1;
    private bool cargando = true;
    private int filtroDias = 30;
    private int filtroDiasEnvios = 30;
    
    // Variables de sucursal y rol
    private int idSucursalUsuario = 0;
    private bool esSuperAdmin = false;
    private bool esAdmin = false;
    private bool esGerente = false;
    
    // Clientes
    private int totalClientes = 0;
    private int clientesActivos = 0;
    private int clientesInactivos = 0;
    private int clientesNuevosMes = 0;
    private List<Cliente> ultimosClientes = new();
    
    // Promociones
    private int totalPromociones = 0;
    private int promocionesActivas = 0;
    private int promocionesInactivas = 0;
    private int promocionesPorVencer = 0;
    private List<Promocion> ultimasPromociones = new();
    
    // Usuarios
    private int totalUsuarios = 0;
    
    // Envíos
    private int totalEnvios = 0;
    private int promedioDiario = 0;
    private List<EnvioConDatos> enviosConDatos = new();

    private class EnvioConDatos
    {
        public DateTime FechaEnvio { get; set; }
        public string? ClienteNombre { get; set; }
        public string? ClienteTelefono { get; set; }
        public string? PromocionTitulo { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarioActual();
        await CargarResumen();
        await CargarClientes();
        await CargarPromociones();
        await CargarEnvios();
        cargando = false;
    }

    private async Task CargarUsuarioActual()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        esSuperAdmin = user.IsInRole("SuperAdministrador");
        esAdmin = user.IsInRole("Administrador");
        esGerente = user.IsInRole("Gerente");
        
        var usuario = await UserManager.GetUserAsync(user);
        if (usuario != null)
        {
            idSucursalUsuario = usuario.IdSucursal ?? 0;
        }
    }

    private async Task CambiarTab(int tab)
    {
        tabActivo = tab;
        StateHasChanged();
    }

    private async Task CargarResumen()
    {
        // Clientes con filtro de sucursal
        var queryClientes = DbContext.Clientes.AsQueryable();
        if (!esSuperAdmin && idSucursalUsuario > 0)
        {
            queryClientes = queryClientes.Where(c => c.IdSucursal == idSucursalUsuario);
        }
        
        totalClientes = await queryClientes.CountAsync();
        clientesActivos = await queryClientes.CountAsync(c => c.Estado == 1);
        clientesInactivos = totalClientes - clientesActivos;
        
        var inicioMes = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        clientesNuevosMes = await queryClientes.CountAsync(c => c.FechaRegistro >= inicioMes);
        
        // Promociones con filtro de sucursal
        var queryPromos = DbContext.Promociones.AsQueryable();
        if (!esSuperAdmin && idSucursalUsuario > 0)
        {
            queryPromos = queryPromos.Where(p => p.IdSucursal == idSucursalUsuario);
        }
        
        totalPromociones = await queryPromos.CountAsync();
        promocionesActivas = await queryPromos.CountAsync(p => p.Activo);
        promocionesInactivas = totalPromociones - promocionesActivas;
        
        var fechaLimite = DateTime.Now.AddDays(7);
        promocionesPorVencer = await queryPromos.CountAsync(p => p.Activo && p.FechaFin <= fechaLimite);
        
        // Envíos con filtro de sucursal (a través de clientes)
        var clientesIds = await queryClientes.Select(c => c.Id).ToListAsync();
        totalEnvios = await DbContext.HistorialEnvios.Where(e => clientesIds.Contains(e.ClienteId)).CountAsync();
        
        totalUsuarios = await DbContext.Users.CountAsync();
    }

    private async Task CargarClientes()
    {
        var query = DbContext.Clientes.AsQueryable();
        
        // Filtro por sucursal
        if (!esSuperAdmin && idSucursalUsuario > 0)
        {
            query = query.Where(c => c.IdSucursal == idSucursalUsuario);
        }
        
        // Filtro por días
        if (filtroDias > 0)
        {
            var fechaLimite = DateTime.Now.AddDays(-filtroDias);
            query = query.Where(c => c.FechaRegistro >= fechaLimite);
        }
        
        totalClientes = await query.CountAsync();
        clientesActivos = await query.CountAsync(c => c.Estado == 1);
        clientesInactivos = totalClientes - clientesActivos;
        ultimosClientes = await query.OrderByDescending(c => c.FechaRegistro).Take(10).ToListAsync();
    }

    private async Task CargarPromociones()
    {
        var query = DbContext.Promociones.AsQueryable();
        
        // Filtro por sucursal
        if (!esSuperAdmin && idSucursalUsuario > 0)
        {
            query = query.Where(p => p.IdSucursal == idSucursalUsuario);
        }
        
        ultimasPromociones = await query.OrderByDescending(p => p.FechaCreacion).Take(10).ToListAsync();
    }

    private async Task CargarEnvios()
    {
        // Obtener clientes de la sucursal
        var queryClientes = DbContext.Clientes.AsQueryable();
        if (!esSuperAdmin && idSucursalUsuario > 0)
        {
            queryClientes = queryClientes.Where(c => c.IdSucursal == idSucursalUsuario);
        }
        var clientesIds = await queryClientes.Select(c => c.Id).ToListAsync();
        
        var query = from h in DbContext.HistorialEnvios
                    join c in DbContext.Clientes on h.ClienteId equals c.Id
                    join p in DbContext.Promociones on h.PromocionId equals p.Id
                    where clientesIds.Contains(h.ClienteId)
                    select new { h.FechaEnvio, ClienteNombre = c.NombreCompleto, ClienteTelefono = c.Telefono, PromocionTitulo = p.Titulo };
        
        if (filtroDiasEnvios > 0)
        {
            var fechaLimite = DateTime.Now.AddDays(-filtroDiasEnvios);
            query = query.Where(x => x.FechaEnvio >= fechaLimite);
        }
        
        totalEnvios = await query.CountAsync();
        var dias = filtroDiasEnvios > 0 ? filtroDiasEnvios : 30;
        promedioDiario = dias > 0 ? totalEnvios / dias : 0;
        
        var resultados = await query.OrderByDescending(x => x.FechaEnvio).Take(10).ToListAsync();
        enviosConDatos = resultados.Select(r => new EnvioConDatos
        {
            FechaEnvio = r.FechaEnvio,
            ClienteNombre = r.ClienteNombre,
            ClienteTelefono = r.ClienteTelefono,
            PromocionTitulo = r.PromocionTitulo
        }).ToList();
    }

    private async Task ExportarExcel()
    {
        try
        {
            string csv = "";
            string nombreArchivo = "";
            
            if (tabActivo == 1)
            {
                var query = DbContext.Clientes.AsQueryable();
                if (!esSuperAdmin && idSucursalUsuario > 0)
                {
                    query = query.Where(c => c.IdSucursal == idSucursalUsuario);
                }
                var clientes = await query.ToListAsync();
                
                csv = "Nombre,Teléfono,Correo,Fecha Registro,Estado\n";
                foreach (var c in clientes)
                    csv += $"\"{c.NombreCompleto}\",\"{c.Telefono}\",\"{c.Correo ?? ""}\",\"{c.FechaRegistro:dd/MM/yyyy}\",\"{(c.Estado == 1 ? "Activo" : "Inactivo")}\"\n";
                nombreArchivo = $"clientes_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            }
            else if (tabActivo == 2)
            {
                var query = DbContext.Promociones.AsQueryable();
                if (!esSuperAdmin && idSucursalUsuario > 0)
                {
                    query = query.Where(p => p.IdSucursal == idSucursalUsuario);
                }
                var promos = await query.ToListAsync();
                
                csv = "Título,Precio,Descuento,Inicio,Fin,Estado\n";
                foreach (var p in promos)
                    csv += $"\"{p.Titulo}\",{p.Precio},\"{(p.DescuentoPorcentaje.HasValue ? $"{p.DescuentoPorcentaje}%" : "-")}\",\"{p.FechaInicio:dd/MM/yyyy}\",\"{p.FechaFin:dd/MM/yyyy}\",\"{(p.Activo ? "Activa" : "Inactiva")}\"\n";
                nombreArchivo = $"promociones_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            }
            else if (tabActivo == 3)
            {
                var queryClientes = DbContext.Clientes.AsQueryable();
                if (!esSuperAdmin && idSucursalUsuario > 0)
                {
                    queryClientes = queryClientes.Where(c => c.IdSucursal == idSucursalUsuario);
                }
                var clientesIds = await queryClientes.Select(c => c.Id).ToListAsync();
                
                var envios = await (from h in DbContext.HistorialEnvios
                                    join c in DbContext.Clientes on h.ClienteId equals c.Id
                                    join p in DbContext.Promociones on h.PromocionId equals p.Id
                                    where clientesIds.Contains(h.ClienteId)
                                    select new { c.NombreCompleto, c.Telefono, p.Titulo, h.FechaEnvio }).ToListAsync();
                
                csv = "Cliente,Teléfono,Promoción,Fecha Envío\n";
                foreach (var e in envios)
                    csv += $"\"{e.NombreCompleto}\",\"{e.Telefono}\",\"{e.Titulo}\",\"{e.FechaEnvio:dd/MM/yyyy HH:mm}\"\n";
                nombreArchivo = $"envios_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            }
            else if (tabActivo == 4)
            {
                csv = "Indicador,Valor\n";
                csv += $"Total Clientes,{totalClientes}\n";
                csv += $"Clientes Activos,{clientesActivos}\n";
                csv += $"Clientes Inactivos,{clientesInactivos}\n";
                csv += $"Total Promociones,{totalPromociones}\n";
                csv += $"Promociones Activas,{promocionesActivas}\n";
                csv += $"Total Envíos,{totalEnvios}\n";
                csv += $"Total Usuarios,{totalUsuarios}\n";
                nombreArchivo = $"resumen_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            }
            
            var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(csv));
            await JS.InvokeVoidAsync("downloadFile", nombreArchivo, base64);
            await JS.InvokeVoidAsync("Swal.fire", "Exportado", "Archivo generado correctamente", "success");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", "Error", $"Error al exportar: {ex.Message}", "error");
        }
    }

    private async Task EliminarTodoConfirmado()
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", "¿Estás seguro de que quieres eliminar todos los datos? Esta acción no se puede deshacer.");
        if (confirmado)
            await EliminarTodo();
    }

    private async Task EliminarTodo()
    {
        try
        {
            if (tabActivo == 1)
            {
                var query = DbContext.Clientes.AsQueryable();
                if (!esSuperAdmin && idSucursalUsuario > 0)
                {
                    query = query.Where(c => c.IdSucursal == idSucursalUsuario);
                }
                var todos = await query.ToListAsync();
                DbContext.Clientes.RemoveRange(todos);
                await DbContext.SaveChangesAsync();
                await CargarClientes();
                await CargarResumen();
                await JS.InvokeVoidAsync("Swal.fire", "Eliminados", "Todos los clientes han sido eliminados", "success");
            }
            else if (tabActivo == 2)
            {
                var query = DbContext.Promociones.AsQueryable();
                if (!esSuperAdmin && idSucursalUsuario > 0)
                {
                    query = query.Where(p => p.IdSucursal == idSucursalUsuario);
                }
                var todos = await query.ToListAsync();
                DbContext.Promociones.RemoveRange(todos);
                await DbContext.SaveChangesAsync();
                await CargarPromociones();
                await CargarResumen();
                await JS.InvokeVoidAsync("Swal.fire", "Eliminadas", "Todas las promociones han sido eliminadas", "success");
            }
            else if (tabActivo == 3)
            {
                var queryClientes = DbContext.Clientes.AsQueryable();
                if (!esSuperAdmin && idSucursalUsuario > 0)
                {
                    queryClientes = queryClientes.Where(c => c.IdSucursal == idSucursalUsuario);
                }
                var clientesIds = await queryClientes.Select(c => c.Id).ToListAsync();
                
                var todos = await DbContext.HistorialEnvios.Where(e => clientesIds.Contains(e.ClienteId)).ToListAsync();
                DbContext.HistorialEnvios.RemoveRange(todos);
                await DbContext.SaveChangesAsync();
                await CargarEnvios();
                await CargarResumen();
                await JS.InvokeVoidAsync("Swal.fire", "Eliminados", "Todos los envíos han sido eliminados", "success");
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
