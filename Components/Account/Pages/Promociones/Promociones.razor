@page "/promociones"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using RamsCottons.Models
@using RamsCottons.Data
@attribute [Authorize]

@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<PageTitle>Gestión de Promociones | RAMS Cottons</PageTitle>

<div class="promociones-container">
    <br>
    <!-- Header -->
    <div class="dashboard-header">
        <div class="header-content">
            <div class="header-title">
                <div class="title-icon">
                    <i class="bi bi-megaphone-fill"></i>
                </div>
                <div>
                    <h1>Gestión de Promociones</h1>
                    <p class="subtitle">Administra las promociones del sistema</p>
                </div>
            </div>
            <button class="btn-create" @onclick="CrearPromocion">
                <i class="bi bi-plus-lg"></i>
                <span>Nueva Promoción</span>
            </button>
        </div>
    </div>

    <!-- Control Panel -->
    <div class="control-panel">
        <div class="panel-header">
            <div class="panel-title">
                <i class="bi bi-table"></i>
                <h3>Tabla de Promociones</h3>
            </div>
            <div class="panel-actions">
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" @bind="filtro" @bind:event="oninput" placeholder="Buscar promociones...">
                </div>
                <div class="action-buttons">
                    <button class="btn-filter" @onclick="ToggleFilters">
                        <i class="bi bi-funnel"></i>
                        Filtros
                    </button>
                    <button class="btn-refresh" @onclick="CargarPromociones">
                        <i class="bi bi-arrow-clockwise @(cargando ? "fa-spin" : "")"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Filtros -->
        <div class="filters-panel @(mostrarFiltros ? "show" : "")">
            <div class="filter-row">
                <div class="filter-group">
                    <label>Estado</label>
                    <select class="select-custom" @bind="filtroEstado">
                        <option value="">Todos</option>
                        <option value="activo">Activas</option>
                        <option value="inactivo">Inactivas</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>Ordenar por</label>
                    <select class="select-custom" @bind="ordenarPor">
                        <option value="reciente">Más recientes primero</option>
                        <option value="antiguo">Más antiguos primero</option>
                        <option value="titulo">Título A-Z</option>
                        <option value="fechaFin">Fecha de fin</option>
                    </select>
                </div>
            </div>

            <div class="filter-row">
                <div class="filter-group">
                    <label>Filas por página</label>
                    <select class="select-custom" @bind="elementosPorPagina">
                        <option value="5">5</option>
                        <option value="10">10</option>
                        <option value="15" selected>15</option>
                        <option value="20">20</option>
                        <option value="25">25</option>
                        <option value="30">30</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>&nbsp;</label>
                    <button class="btn-clear-filters" @onclick="LimpiarFiltros">
                        <i class="bi bi-x-circle"></i>
                        Limpiar Filtros
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Loading -->
    @if (cargando)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 text-muted">Cargando promociones...</p>
        </div>
    }
    else
    {
        <!-- Main Table -->
        <div class="table-container">
            <div class="table-responsive">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Precio</th>
                            <th>Descuento</th>
                            <th>Fecha Inicio</th>
                            <th>Fecha Fin</th>
                            <th>Estado</th>
                            <th>Enlace</th>
                            <th>Acciones</th>
                            </tr>
                        </thead>
                    <tbody>
                        @if (!promocionesPaginadas.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <div class="no-data">
                                        <i class="bi bi-megaphone display-4 text-muted"></i>
                                        <p class="mb-0">No hay promociones registradas</p>
                                        <button class="btn btn-sm btn-primary mt-3" @onclick="CrearPromocion">
                                            <i class="bi bi-plus-lg"></i> Crear primera promoción
                                        </button>
                                    </div>
                                </td>
                                </tr>
                        }
                        else
                        {
                            @foreach (var promo in promocionesPaginadas)
                            {
                                var enlace = $"https://marquis-leavenless-nonseparably.ngrok-free.dev/promociones/{promo.TokenUnico}";
                                <tr class="promo-row">
                                    <td class="col-titulo">
                                        <div class="titulo-info">
                                            <i class="bi @(promo.pdf_url?.EndsWith(".pdf") == true ? "bi-file-earmark-pdf-fill text-danger" : "bi-file-earmark-image-fill text-primary")"></i>
                                            <span class="titulo-nombre">@promo.Titulo</span>
                                        </div>
                                        <small class="text-muted">@promo.Descripcion</small>
                                    </td>
                                    <td class="col-precio">
                                        <span class="precio">$@promo.Precio.ToString("N2")</span>
                                    </td>
                                    <td class="col-descuento">
                                        @if (promo.DescuentoPorcentaje.HasValue)
                                        {
                                            <span class="descuento-badge">@promo.DescuentoPorcentaje% OFF</span>
                                        }
                                        else if (promo.DescuentoMonto.HasValue)
                                        {
                                            <span class="descuento-badge">$@promo.DescuentoMonto OFF</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="col-fecha">
                                        @promo.FechaInicio.ToString("dd/MM/yyyy")
                                    </td>
                                    <td class="col-fecha">
                                        @promo.FechaFin.ToString("dd/MM/yyyy")
                                    </td>
                                    <td class="col-estado">
                                        <span class="status-badge @(promo.Activo ? "status-active" : "status-inactive")">
                                            <i class="bi @(promo.Activo ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                                            @(promo.Activo ? "Activa" : "Inactiva")
                                        </span>
                                    </td>
                                    <td class="col-enlace">
                                        <button class="btn-copy-link" @onclick="() => CopiarEnlace(enlace)">
                                            <i class="bi bi-files"></i>
                                            <span>Copiar</span>
                                        </button>
                                    </td>
                                    <td class="col-acciones">
                                        <div class="action-buttons">
                                            <button class="btn-action btn-edit" @onclick="() => EditarPromocion(promo.Id)" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn-action btn-toggle" @onclick="() => ToggleEstado(promo)" title="@(promo.Activo ? "Desactivar" : "Activar")">
                                                <i class="bi @(promo.Activo ? "bi-pause-circle" : "bi-play-circle")"></i>
                                            </button>
                                            <button class="btn-action btn-delete" @onclick="() => ConfirmarEliminar(promo)" title="Eliminar">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- Paginación -->
            @if (promocionesFiltradas.Any())
            {
                <div class="table-footer">
                    <div class="footer-info">
                        <div class="total-count">
                            Mostrando <span>@promocionesPaginadas.Count()</span> de <span>@promocionesFiltradas.Count()</span> promociones
                        </div>
                        <div class="pagination-info">
                            Página @paginaActual de @totalPaginas
                        </div>
                    </div>

                    @if (totalPaginas > 1)
                    {
                        <div class="pagination-wrapper">
                            <ul class="pagination">
                                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual - 1)">
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                </li>
                                @for (int i = 1; i <= totalPaginas; i++)
                                {
                                    if (i == 1 || i == totalPaginas || (i >= paginaActual - 2 && i <= paginaActual + 2))
                                    {
                                        <li class="page-item @(i == paginaActual ? "active" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(i)">@i</button>
                                        </li>
                                    }
                                    else if (i == paginaActual - 3 || i == paginaActual + 3)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                }
                                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual + 1)">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Promocion> promociones = new();
    private bool cargando = true;
    private bool mostrarFiltros = false;
    private string filtro = "";
    private string filtroEstado = "";
    private string ordenarPor = "reciente";
    private int paginaActual = 1;
    private int elementosPorPagina = 15;
    
    // Variables para roles y sucursal
    private int idSucursalUsuario = 0;
    private bool esSuperAdmin = false;
    private bool esAdmin = false;
    private bool esGerente = false;
    private bool esVendedor = false;

    private IEnumerable<Promocion> promocionesFiltradas
    {
        get
        {
            var query = promociones.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(filtro))
            {
                query = query.Where(p =>
                    p.Titulo.Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                    (p.Descripcion != null && p.Descripcion.Contains(filtro, StringComparison.OrdinalIgnoreCase))
                );
            }

            if (filtroEstado == "activo")
            {
                query = query.Where(p => p.Activo);
            }
            else if (filtroEstado == "inactivo")
            {
                query = query.Where(p => !p.Activo);
            }

            query = ordenarPor switch
            {
                "antiguo" => query.OrderBy(p => p.FechaCreacion),
                "titulo" => query.OrderBy(p => p.Titulo),
                "fechaFin" => query.OrderBy(p => p.FechaFin),
                _ => query.OrderByDescending(p => p.FechaCreacion)
            };

            return query;
        }
    }

    private int totalPaginas => (int)Math.Ceiling((double)promocionesFiltradas.Count() / elementosPorPagina);
    
    private IEnumerable<Promocion> promocionesPaginadas =>
        promocionesFiltradas
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina);

    protected override async Task OnInitializedAsync()
    {
        await CargarPromociones();
    }

    private async Task CargarPromociones()
    {
        cargando = true;
        try
        {
            var query = DbContext.Promociones.AsQueryable();
            
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var usuario = await UserManager.GetUserAsync(user);
            
            esSuperAdmin = user.IsInRole("SuperAdministrador");
            esAdmin = user.IsInRole("Administrador");
            esGerente = user.IsInRole("Gerente");
            esVendedor = user.IsInRole("Vendedor");
            
            // Obtener sucursal del usuario actual
            if (usuario != null)
            {
                idSucursalUsuario = usuario.IdSucursal ?? 0;
            }
            
            // 🔥 FILTRO POR ROL Y SUCURSAL
            if (esSuperAdmin)
            {
                // SuperAdmin ve todas las promociones
            }
            else if (esAdmin)
            {
                // Administrador ve las promociones de su sucursal
                if (idSucursalUsuario > 0)
                {
                    query = query.Where(p => p.IdSucursal == idSucursalUsuario);
                }
            }
            else if (esGerente || esVendedor)
            {
                // Gerente y Vendedor ven las promociones activas de su sucursal
                query = query.Where(p => p.Activo == true);
                if (idSucursalUsuario > 0)
                {
                    query = query.Where(p => p.IdSucursal == idSucursalUsuario);
                }
            }
            
            promociones = await query
                .OrderByDescending(p => p.FechaCreacion)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task CopiarEnlace(string enlace)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", enlace);
        await JS.InvokeVoidAsync("Swal.fire", new
        {
            title = "¡Enlace copiado!",
            text = "El enlace se ha copiado al portapapeles",
            icon = "success",
            confirmButtonText = "Aceptar",
            timer = 2000,
            showConfirmButton = false
        });
    }

    private void CrearPromocion() => NavigationManager.NavigateTo("/promociones/crear");
    private void EditarPromocion(int id) => NavigationManager.NavigateTo($"/promociones/editar/{id}");
    private void ToggleFilters() => mostrarFiltros = !mostrarFiltros;
    private void LimpiarFiltros() { filtro = ""; filtroEstado = ""; }
    private void CambiarPagina(int pagina) => paginaActual = pagina;

    private async Task ToggleEstado(Promocion promo)
    {
        promo.Activo = !promo.Activo;
        await DbContext.SaveChangesAsync();
        await CargarPromociones();
    }

    private async Task ConfirmarEliminar(Promocion promo)
    {
        DbContext.Promociones.Remove(promo);
        await DbContext.SaveChangesAsync();
        await CargarPromociones();
    }
}
