@page "/Account/ForgotPasswordConfirmation"
@layout RamsCottons.Components.Layout.AuthLayout

<PageTitle>Correo enviado | Rams Cottons</PageTitle>

<div class="login-container">
    <div class="login-card" style="text-align: center;">
        <div class="login-header">
            <div style="background: rgba(255, 102, 0, 0.1); width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                <svg xmlns="http://www.w3.org/2000/svg" style="width: 30px; color: #ff6600;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
            </div>
            <h2 class="login-title">Revisa tu correo</h2>
            <p class="login-subtitle">Si la cuenta existe, hemos enviado un enlace para restablecer tu contraseña.</p>
        </div>

        <div class="register-section">
            <a href="Account/Login" class="login-button" style="text-decoration: none; display: block;">Regresar al inicio</a>
        </div>
    </div>
</div>