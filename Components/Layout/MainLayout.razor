@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between">

            <!-- BOTÓN PARA ENCOGER MENU SIDEBAR -->
            <button class="btn-menu" onclick="toggleSidebar()">
                <i id="menuIcon" class="bi bi-list"></i>
            </button>

            <!-- BOTÓN FULLSCREEN -->
            <button class="btn-fullscreen" onclick="toggleFullscreenJS()">
                <i class="bi"></i>
            </button>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>